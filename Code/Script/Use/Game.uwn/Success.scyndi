Module

#use "Script/Use/Anyway"
#accept SetStage

plua Banner = ObtainImage("ENDPUZZLE_SUCCESS")

Bool NewBestTime
Bool NewBestTool
Bool NewMostBalls

Void NextPuzzle()
	gint.PuzzleChosen++
	Puz[Ternary(Upper(gStr.PackType)=="INTERNAL","iLoad","Load")](gstr.PackChosen,gint.PuzzleChosen)
	Puz.BPAM.Renew()
	Puz.Actors.Compile()
	SetStage("Start")
End

Bool AllowNext()
	Return False
End


ReadOnly Var Menu
Init
	GGA:=Game.GameMenu.Add
	Menu = {}
	Menu+=GGA("NEXT",Game.NextPuzzle,AllowNext)
	Menu+=GGA("SAME",Game.Fail.SamePuzzle)
	Game.GameMenu.BaseItems(Menu)
End

Void SMain()
	SetColor(255,255,255,255)
	Banner.Draw(Graphics.W div 2,Graphics.H div 3)
End
